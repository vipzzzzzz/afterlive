---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VideoCard from '@/components/VideoCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="AfterAfterLive" heavyOverlay={true} showFooter={false}>
  <main class="videos-page">
    <div class="video-scroll">
      {posts.map((post) => (
        <VideoCard
          title={post.data.title}
          date={post.data.date}
          youtubeId={post.data.youtubeId}
        />
      ))}
    </div>
  </main>

  <div class="video-overlay" id="video-overlay">
    <button class="video-overlay-close" id="video-overlay-close" aria-label="Close video">&times;</button>
    <div class="video-overlay-player">
      <iframe
        id="video-iframe"
        width="100%"
        height="100%"
        src=""
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <script>
    function initVideoCards() {
      const overlay = document.getElementById('video-overlay');
      const iframe = document.getElementById('video-iframe') as HTMLIFrameElement;
      const closeBtn = document.getElementById('video-overlay-close');
      if (!overlay || !iframe || !closeBtn) return;

      document.querySelectorAll('.video-card').forEach((card) => {
        const ytId = (card as HTMLElement).dataset.youtubeId;
        card.querySelector('.video-card-btn')?.addEventListener('click', () => {
          iframe.src = `https://www.youtube-nocookie.com/embed/${ytId}?autoplay=1`;
          overlay.classList.add('active');
        });
      });

      function close() {
        overlay.classList.remove('active');
        iframe.src = '';
      }

      closeBtn.addEventListener('click', close);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('active')) close();
      });
    }

    initVideoCards();
    document.addEventListener('astro:after-swap', initVideoCards);
  </script>
</BaseLayout>
